# Exemplo de variáveis de ambiente. Copie para `.env.local` no desenvolvimento.
# Na Vercel: Settings → Environment Variables (Production / Preview conforme o caso).
# Não commite arquivos `.env` ou `.env.local` com valores reais.

# ---------------------------------------------------------------------------
# URL pública da aplicação (recomendado em produção para redirects do Stripe
# e OAuth). Deve coincidir com o domínio canônico do deploy.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=

# ---------------------------------------------------------------------------
# Stripe — somente servidor (nunca prefixo NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs obrigatórios para checkout (mensal). Anuais opcionais.
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_BUSINESS_ANNUAL=

# Opcionais — úteis para “Publicar no Stripe” no admin (platform commercial).
STRIPE_PRODUCT_ID_PRO=
STRIPE_PRODUCT_ID_BUSINESS=

# Opcionais — URLs de retorno do Checkout (se vazios, usam /{locale}/billing/checkout/return?result=… em lib/billing.ts).
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=
