# Exemplo de variáveis de ambiente. Copie para `.env.local` no desenvolvimento.
# Na Vercel: Settings → Environment Variables (Production / Preview conforme o caso).
# Não commite arquivos `.env` ou `.env.local` com valores reais.

# ---------------------------------------------------------------------------
# Redis (opcional) — Pub/Sub para fan-out de eventos de board (card_move,
# column_reorder, drag_*, locks, etc.) entre várias instâncias Node.
#
# Formato: URL TCP redis:// ou rediss:// (TLS), por exemplo Upstash.
# A API REST do Upstash não suporta SUBSCRIBE; o subscritor em
# instrumentation.ts usa cliente TCP (ioredis) e precisa de processo Node
# de longa duração com esse processo ativo.
#
# Limitação serverless: em deploys onde cada pedido é efémero e não há
# worker sempre ligado, o subscritor Redis pode não ficar ativo — nesse caso
# não há replicação entre instâncias. Fallback: hub SSE em memória na
# instância que atendeu o POST + polling do cliente por lastUpdated.
#
# Sem REDIS_URL: apenas hub in-memory no processo atual (OK para dev ou
# instância única).
# ---------------------------------------------------------------------------
REDIS_URL=

# ---------------------------------------------------------------------------
# URL pública da aplicação (recomendado em produção para redirects do Stripe
# e OAuth). Use o mesmo host que o utilizador vê (ex.: https://www.flux-board.com),
# sem espaços no fim. Se o tráfego usar www e apex, registe ambos os redirect URIs
# OAuth; quando o host do pedido difere desta variável, o servidor alinha o OAuth ao host do pedido.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=

# ---------------------------------------------------------------------------
# OAuth — cookie de state (httpOnly) partilhado entre apex e www (produção).
# Ex.: flux-board.com (sem ponto inicial, sem https). Ver também OAUTH_ALLOWED_PUBLIC_ORIGINS.
# ---------------------------------------------------------------------------
AUTH_COOKIE_DOMAIN=

# ---------------------------------------------------------------------------
# Sessão — teto interno (ms) para validação em GET /api/auth/session (503 JSON evita 504 longo).
# Ex.: 35000 — alinhado a MONGO_SOCKET_TIMEOUT_MS / cold start. Ver docs/oauth-session-diagnostics.md.
# ---------------------------------------------------------------------------
FLUX_SESSION_VALIDATE_WALL_MS=

# ---------------------------------------------------------------------------
# UI — atraso antes do primeiro GET /api/boards na lista (cold start; competição com /api/auth/session).
# Público: 0 desliga; default ~200 ms se omitido no cliente.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FLUX_BOARDS_STAGGER_MS=

# ---------------------------------------------------------------------------
# UI — mesmo padrão para onboarding (já usado em app/onboarding/page.tsx).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FLUX_ONBOARDING_BOARDS_STAGGER_MS=

# ---------------------------------------------------------------------------
# OAuth (produção) — origins públicos HTTPS permitidos (espelho do Google Cloud / Azure).
# CSV ou JSON array, sem path obrigatório (ex.: https://www.flux-board.com,https://flux-board.com).
# Com Google ou Microsoft OAuth ativo em NODE_ENV=production, a lista é obrigatória e não vazia;
# pedidos cujo host não esteja na lista recebem 403 { "error":"oauth_host_not_allowed" }.
# Em desenvolvimento / testes, vazio = comportamento anterior (qualquer host do pedido).
# ---------------------------------------------------------------------------
OAUTH_ALLOWED_PUBLIC_ORIGINS=

# ---------------------------------------------------------------------------
# Opcional (produção) — redirecionar pedidos documento/HTML de hosts “alias” para o origin canónico.
# Ex.: SITE_CANONICAL_ORIGIN=https://www.flux-board.com e SITE_HOST_ALIASES=flux-board.com
# → 308 de https://flux-board.com/... para https://www.flux-board.com/... (só HTML; /api/ não passa aqui).
# Deixe vazio em preview (*.vercel.app) se não quiser redirecionar esses hosts.
# ---------------------------------------------------------------------------
SITE_CANONICAL_ORIGIN=
SITE_HOST_ALIASES=

# Opcional: log em GET /api/boards quando a lista vem vazia para utilizador não-admin (diagnóstico P4).
FLUX_LOG_EMPTY_BOARD_LIST=

# Opcional: diagnóstico de sessão/OAuth no servidor (logs JSON com prefixo [flux-auth-debug]).
# Não ativar em produção sem necessidade (volume e contexto de pedido).
FLUX_AUTH_DEBUG=

# ---------------------------------------------------------------------------
# Stripe — somente servidor (nunca prefixo NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs obrigatórios: price_... (cada PREÇO na Stripe). NÃO use prod_... (produto) nem valor em R$.
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_BUSINESS_ANNUAL=

# Opcionais — úteis para “Publicar no Stripe” no admin (platform commercial).
STRIPE_PRODUCT_ID_PRO=
STRIPE_PRODUCT_ID_BUSINESS=

# Opcionais — URLs de retorno do Checkout (se vazios, usam /{locale}/billing/checkout/return?result=… em lib/billing.ts).
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=
